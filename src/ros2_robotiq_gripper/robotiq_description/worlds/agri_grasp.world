<?xml version="1.0" ?>
<sdf version="1.9">
<world name="agri_grasp_world">

  <plugin filename="gz-sim-physics-system"
          name="gz::sim::systems::Physics"/>
  <plugin filename="gz-sim-user-commands-system"
          name="gz::sim::systems::UserCommands"/>
  <plugin filename="gz-sim-scene-broadcaster-system"
          name="gz::sim::systems::SceneBroadcaster"/>

  <!-- Essential Ground Plane so falling objects have a floor -->
  <model name="ground_plane">
    <static>true</static>
    <link name="link">
      <collision name="collision">
        <geometry>
          <plane><normal>0 0 1</normal><size>100 100</size></plane>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <plane><normal>0 0 1</normal><size>100 100</size></plane>
        </geometry>
        <material>
          <ambient>0.8 0.8 0.8 1</ambient>
          <diffuse>0.8 0.8 0.8 1</diffuse>
        </material>
      </visual>
    </link>
  </model>

  <light type="directional" name="sun">
    <cast_shadows>true</cast_shadows>
    <pose>0 0 10 0 0 0</pose>
    <diffuse>0.8 0.8 0.8 1</diffuse>
    <specular>0.2 0.2 0.2 1</specular>
    <attenuation>
      <range>1000</range>
      <constant>0.9</constant>
      <linear>0.01</linear>
      <quadratic>0.001</quadratic>
    </attenuation>
    <direction>-0.5 0.1 -0.9</direction>
  </light>

  <include>
    <uri>model://tree_branch</uri>
    <name>my_tree_branch</name>
    <static>true</static>
    <!-- Raised to 0.8m, rotated 90 degrees around Y (pitch) to lay flat -->
    <pose>0 0 0.8 0 1.5708 0</pose> 
  </include>

  <include>
    <uri>model://orange</uri>
    <name>target_fruit</name>
    <static>false</static> 
    <!-- Locked in from GUI coordinates -->
    <pose>-0.2600 0.1384 0.7665 -2.1000 -0.1000 -0.9878</pose> 
  </include>

  <!-- The Swinging Joint -->
  <joint name="orange_stem_joint" type="ball">
    <parent>my_tree_branch::branch_link</parent>
    <child>target_fruit::link</child>
    <pose>0 0 0.0500 0 0 0</pose>
  </joint>

</world>
</sdf>